# Deepfake Shield backend configuration

# SQLite path (mounted as a volume in docker-compose)
DB_PATH=/data/deepfake_shield.db

# Allowed CORS origins (comma separated). Use "*" for any origin in dev.
CORS_ORIGINS=*

# Service identity reported by /v1/health and /v1/model/status
SERVICE_VERSION=deepfake-shield-1.0

# Reserved for future ONNX integration
MODEL_PATH=/models/rawnet3.onnx

# High-risk threshold above which sightings are exported via /v1/threat-intel as STIX indicators
HIGH_RISK_THRESHOLD=0.65
